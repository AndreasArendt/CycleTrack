rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function activityDocument(activityId) {
      return get(/databases/$(database)/documents/activities/$(activityId));
    }

    function isActivityOwner(activityId) {
      return isOwner(activityDocument(activityId).data.ownerUid);
    }

    function isActivityWatcher(activityId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/activities/$(activityId)/watchers/$(request.auth.uid));
    }

    function invitationDocument(activityId, invitationId) {
      return get(/databases/$(database)/documents/activities/$(activityId)/invitations/$(invitationId));
    }

    function isValidInvitation(activityId, invitationId) {
      return invitationId is string
        && exists(/databases/$(database)/documents/activities/$(activityId)/invitations/$(invitationId))
        && !("revokedAt" in invitationDocument(activityId, invitationId).data);
    }

    match /trackingEntries/{entryId} {
      allow create: if isOwner(request.resource.data.ownerUid)
        && request.resource.data.riderId == request.auth.uid;

      allow read, update, delete: if isOwner(resource.data.ownerUid);
    }

    match /riderLocations/{riderId} {
      allow read, write: if isOwner(riderId);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
    }

    match /activities/{activityId} {
      allow read: if isSignedIn()
        && (isOwner(resource.data.ownerUid) || isActivityWatcher(activityId));
      allow create: if isOwner(request.resource.data.ownerUid);
      allow update, delete: if isOwner(resource.data.ownerUid);

      match /invitations/{invitationId} {
        allow read: if isSignedIn();
        allow create: if isActivityOwner(activityId)
          && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if isActivityOwner(activityId);
      }

      match /watchers/{watcherId} {
        allow read: if isSignedIn();
        allow create: if isOwner(watcherId)
          && isValidInvitation(activityId, request.resource.data.invitationId);
        allow update: if isOwner(watcherId)
          && request.resource.data.invitationId == resource.data.invitationId;
        allow delete: if isOwner(watcherId)
          || isActivityOwner(activityId);
      }
    }
  }
}
